<Project Sdk="WixToolset.Sdk/6.0.2">
  <PropertyGroup>
    <OutputType>Package</OutputType>
    <OutputName>VRDeveloperUtilitySetup</OutputName>
    <Platform>x64</Platform>
    <SourceDir Condition="'$(SourceDir)' == ''">..\dist\app</SourceDir>
    <DefineConstants>SourceDir=$(SourceDir)</DefineConstants>
    <SuppressIces>ICE91</SuppressIces>
  </PropertyGroup>
</Project>
